{
  "name": "file-curator",
  "label": "File Curator",
  "description": "Curates a given file, to be used as a gear rule",
  "version": "0.1.0",
  "custom": {
    "gear-builder": {
      "category": "converter",
      "image": "flywheel/file-curator:0.1.0"
    },
    "flywheel": {
      "suite": "Curation"
    }
  },
  "inputs": {
    "api-key": {
      "base": "api-key",
      "read-only": true
    },
    "curator": {
      "base": "file",
      "description": "A python implementation of the FileCurator class (see https://gear-toolkit.readthedocs.io/en/latest/utils.html#curator for more details).",
      "type": {
        "enum": [
          "source code"
        ]
      }
    },
    "file-input": {
      "base": "file",
      "description": "File to curate"
    },
    "additional-input-one": {
      "base": "file",
      "description": "An optional input for curation.",
      "optional": true
    },
    "additional-input-two": {
      "base": "file",
      "description": "An optional input for curation.",
      "optional": true
    }
  },
  "config": {
    "debug": {
      "description": "Log debug messages",
      "type": "boolean",
      "default": false
    }
  },
  "environment": {},
  "command": "./run.py",
  "author": "Flywheel",
  "maintainer": "Flywheel <support@flywheel.io>",
  "cite": "",
  "license": "MIT",
  "source": "https://github.com/flywheel-apps/custom-curator",
  "url": "https://github.com/flywheel-apps/custom-curator"
}